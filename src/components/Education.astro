---
import EducationItem from "./EducationItem.astro"

const EDUCATION = [
    {
        date: "2024 - 2026",
        degree: "Master of Science",
        institution: "Viterbi School of Engineering, University of Southern California, Los Angeles",
        description:
            "Specialization in Computer Science. Relevant coursework includes Analysis of Algorithms, Database Systems, Applied Natural Language Processing, Web Technologies, Advanced Mobile Devices and Game Consoles, Software Architectures, Applied Cryptography and Information Retrieval and Web Search Engines.",
        grade:"3.55 GPA"
        
    },

{
        date: "2020 - 2024",
        degree: "Bachelor of Technology",
        institution: "Indus Institute of Technology & Engineering, Indus University, Ahmedabad",
        description:
            "Specialization in Computer Science and Engineering. Relevant coursework includes Data Structures, Algorithms, Machine Learning, Web Development, Operating System and more.",
        grade:"3.86 GPA"    
    }
    
    // Add more education items here
]
---
<ol class="relative mt-16">
    {
        EDUCATION.map((education) => (
            <li class="education">
                <EducationItem {...education} />
            </li>
        ))
    }
</ol>
